PGHOST=127.0.0.1
PGPORT=54322
PGUSER=postgres
PGDATABASE=postgres
PGPASSWORD=postgres
PGSSLMODE=disable
PGSSLREJECTUNAUTHORIZED=true

YAHOO_CLIENT_ID=your-yahoo-client-id
KANA_KURONEKO_API_URL=https://eng-jpn-api.krnk.org/query
KANA_YAHOO_FURIGANA_API_URL=https://jlp.yahooapis.jp/FuriganaService/V2/furigana

# Optional local-only fallback for old kana.py style Client ID storage.
# KANA_LEGACY_CLIENT_ID_PATH=/Volumes/DATA4 8T/myprogram/lib/kana.py

# Note:
# - The current Next.js app connects to Supabase Postgres directly with PG* variables.
# - Local development can use `PGSSLMODE=disable`.
# - Supabase test / production deployments should use `PGSSLMODE=require`.
# - If your provider returns `SELF_SIGNED_CERT_IN_CHAIN`, set `PGSSLREJECTUNAUTHORIZED=false`.
# - NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY are not used by the current app runtime.
